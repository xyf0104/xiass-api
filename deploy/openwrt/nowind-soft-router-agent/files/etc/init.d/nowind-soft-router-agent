#!/bin/sh /etc/rc.common

START=98
STOP=10
USE_PROCD=1

CONFIG_NAME="nowind_soft_router_agent"
SERVICE_BIN="/usr/bin/nowind-soft-router-agent"

start_service() {
	enabled="$(uci -q get "$CONFIG_NAME.main.enabled" 2>/dev/null || echo 0)"
	[ "$enabled" = "1" ] || return 0

	procd_open_instance
	procd_set_param command "$SERVICE_BIN"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

reload_service() {
	stop
	start
}

stop_service() {
	"$SERVICE_BIN" --stop-frpc >/dev/null 2>&1 || true
}

