config agent 'main'
	option enabled '0'
	option api_url 'https://api.example.com'
	option agent_token ''
	option interval '20'
	option frpc_bin '/usr/bin/frpc'
	option frpc_config '/etc/frp/xiass-soft-router-frpc.ini'
	option frpc_pid_file '/var/run/xiass-soft-router-agent/frpc.pid'
	option local_ip '127.0.0.1'
	option include_passwall '1'
	option include_passwall2 '1'
	option extra_socks ''
	option exit_probe_host ''
	option exit_probe_port '0'
	option exit_probe_timeout '5'
	option exit_probe_protocol 'auto'
	option log_file '/var/log/xiass-soft-router-agent.log'
	option log_max_size '5M'
	option log_backups '5'
	option config_version '3'
	option migration_state 'fresh'
