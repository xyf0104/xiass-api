[Unit]
Description=XIASS API Data Management Daemon
After=network.target
Wants=network.target

[Service]
Type=simple
User=xiass
Group=xiass
WorkingDirectory=/opt/xiass-api
ExecStart=/opt/xiass-api/datamanagementd \
  -socket-path /tmp/xiass-api-datamanagement.sock \
  -sqlite-path /var/lib/xiass-api/datamanagement/datamanagementd.db \
  -version 1.0.0
Restart=always
RestartSec=5s
LimitNOFILE=100000
NoNewPrivileges=true
PrivateTmp=false

[Install]
WantedBy=multi-user.target
